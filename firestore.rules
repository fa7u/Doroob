rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'langmix2@gmail.com' && request.auth.token.email_verified == true;
    }

    function isValidConfig(data) {
      return data.keys().hasAll(['hero', 'features', 'team', 'join', 'footer', 'updatedAt'])
        && data.hero is map
        && data.features is map
        && data.team is map
        && data.join is map
        && data.updatedAt is string;
    }

    // Deep Catch-all Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Application Configuration
    match /settings/config {
      allow read: if true;
      allow create, update: if isAdmin() && isValidConfig(request.resource.data);
      allow delete: if false; // Config should never be deleted
    }

    // Legacy or other paths protection
    match /test/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
