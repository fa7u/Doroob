rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'langmix2@gmail.com' && request.auth.token.email_verified == true;
    }

    // Deep Catch-all Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Application Configuration & Master Documents
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /investments/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Legacy or other paths protection
    match /test/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
